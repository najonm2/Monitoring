# Docker ignore file - excludes unnecessary files from Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.virtualenv/

# Django
*.log
db.sqlite3
db.sqlite3-journal
/staticfiles/
/media/
/sent_emails/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
docs/
README.md
LICENSE

# Tests
test_*.py
*_test.py
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/

# CI/CD
.github/
.gitlab-ci.yml
Jenkinsfile

# Development scripts
test_*.py
deploy_*.ps1
*.sh

# Environment files (NEVER include in Docker image)
.env
.env.*
*.env

# Windows
Thumbs.db
desktop.ini

# Project specific
pmcmd_test.txt
pmcmd_error.txt
*.bak
*.old
